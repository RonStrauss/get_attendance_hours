{
	"version": "1.0.0",
	"license": "MIT",
	"main": "dist/index.js",
	"typings": "dist/index.d.ts",
	"files": [
		"dist",
		"src"
	],
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"start": "npm run start:hilan:webtime",
		"ui:dev": "npm --prefix frontend run dev",
		"ui:build": "npm --prefix frontend run build",
		"start:synerion:webtime": "npm run build && cross-env SCRAPING_TARGET=synerion AUTOMATION_TARGET=webtime node dist",
		"start:hilan:webtime": "npm run build && cross-env SCRAPING_TARGET=hilan AUTOMATION_TARGET=webtime node dist",
		"build": "tsup src/index.ts --format esm,cjs --dts",
		"lint": "eslint --fix",
		"test:browser": "vitest"
	},
	"husky": {
		"hooks": {
			"pre-commit": "npm run lint",
			"pre-start": "npm run build"
		}
	},
	"prettier": {
		"printWidth": 110,
		"semi": true,
		"singleQuote": true,
		"trailingComma": "all",
		"bracketSpacing": true,
		"tabWidth": 2,
		"useTabs": true
	},
	"name": "get_attendance_hours",
	"author": "RonStrauss",
	"module": "dist/index.mjs",
	"devDependencies": {
		"@eslint/js": "^9.24.0",
		"@types/express": "^5.0.6",
		"@types/node": "^22.19.7",
		"@vitest/browser": "^3.1.1",
		"cross-env": "^7.0.3",
		"eslint": "^9.24.0",
		"husky": "^9.1.7",
		"prettier": "^3.5.3",
		"ts-node": "^10.9.2",
		"tsup": "^8.4.0",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.29.1",
		"vitest": "^3.1.1",
		"zod": "^4.3.6"
	},
	"dependencies": {
		"dotenv": "^16.4.7",
		"express": "^5.2.1",
		"puppeteer": "^24.6.0"
	}
}
